# PostgreSQL Connection String (Neon)
DATABASE_URL="postgresql://user:password@ep-host.region.pooler.neon.tech/neondb?sslmode=require"

# NextAuth / Auth.js Configuration
# Generate a secret using: openssl rand -base64 32
AUTH_SECRET="your_nextauth_secret_here"
NEXTAUTH_SECRET="your_nextauth_secret_here"
NEXTAUTH_URL="http://localhost:3000"

# Gemini API Key
GEMINI_API_KEY="your_gemini_api_key_here"

# Public App URL (For Webhook Simulator Callbacks)
NEXT_PUBLIC_APP_URL="http://localhost:3000"
